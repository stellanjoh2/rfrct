{
  "name": "refrct-workspace",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w refrct-editor",
    "dev:editor": "npm run dev -w refrct-editor",
    "dev:blod": "npm run dev -w blod",
    "build": "npm run build -w refrct-editor && npm run build -w blod",
    "build:editor": "npm run build -w refrct-editor",
    "build:blod": "npm run build -w blod",
    "preview:editor": "npm run preview -w refrct-editor",
    "preview:blod": "npm run preview -w blod",
    "push:blod": "bash scripts/push-blod-to-blod-repo.sh"
  }
}
